# =====================================================================
# Cursus — Template de variables d'environnement
# =====================================================================
# Copier ce fichier vers `.env.local` (dev) ou configurer en Vercel (prod).
# JAMAIS commiter `.env.local`. Vérifié par gitleaks pre-commit.
# =====================================================================


# ---------------------------------------------------------------------
# 1. APPLICATION
# ---------------------------------------------------------------------

# URL publique de l'app (utilisée pour les liens dans les emails, OG, certificats)
# Dev: http://localhost:3000
# Prod: https://cursus.app (à remplacer)
NUXT_PUBLIC_SITE_URL="http://localhost:3000"

# Environnement (development | preview | production) — cf. server/utils/env.ts
NUXT_PUBLIC_ENVIRONMENT="development"

# Nom de l'app (peut être surchargé pour le white-label)
NUXT_PUBLIC_APP_NAME="Cursus"

# Secret de session Nuxt (générer avec: openssl rand -base64 32)
NUXT_SESSION_SECRET="changeme-generate-with-openssl-rand-base64-32"

# Signature des URLs OG dynamiques (nuxt-og-image) — empêche les requêtes arbitraires
# Générer: npx nuxt-og-image generate-secret  (ou: openssl rand -hex 32)
NUXT_OG_IMAGE_SECRET="changeme-hex-32"


# ---------------------------------------------------------------------
# 2. SUPABASE — Auth + Storage + Realtime + Postgres
# ---------------------------------------------------------------------

# URL projet Supabase (Dashboard → Settings → API → Project URL)
NUXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Clé publique anon (côté client autorisé) — non sensible
NUXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc..."

# Clé service role (POUVOIR ADMIN — UNIQUEMENT côté serveur Nitro)
# Permet de bypass la RLS pour les jobs système (Inngest, webhooks)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."

# Region de déploiement (pour la doc, pas utilisé directement par l'app)
SUPABASE_REGION="eu-west-3"

# Plan : Free tier au démarrage (500MB DB, 1GB Storage, 50K MAU,
# PAUSE AUTO après 7j d'inactivité). Workaround pause : Inngest cron
# qui ping la DB une fois par jour (cf. server/inngest/keepalive.ts).
# Upgrade vers Pro ($25/mois) recommandé pour prod stable.
SUPABASE_PLAN="free"


# ---------------------------------------------------------------------
# 3. PRISMA — Connection strings (Supabase Postgres)
# ---------------------------------------------------------------------

# Pooled connection (Supavisor) — utilisée par Prisma Client au runtime
# Format: postgresql://postgres.<ref>:<pwd>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Le port 6543 = pooler transaction mode (recommandé serverless)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:CHANGEME@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection — utilisée par `prisma migrate dev/deploy`
# Format identique mais port 5432 (les migrations ne supportent pas pgBouncer)
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:CHANGEME@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"


# ---------------------------------------------------------------------
# 4. GITHUB APP — Harnais Cursus
# ---------------------------------------------------------------------

# ID de la GitHub App (Settings org → Developer settings → GitHub Apps → App ID)
GITHUB_APP_ID="123456"

# Installation ID (Settings → Installation → ID dans l'URL)
CURSUS_GITHUB_APP_INSTALLATION_ID="98765432"

# Private key de la GitHub App (téléchargée à la création)
# Format: la clé PEM ENTIÈRE sur une seule ligne avec \n littéraux
# Tip: cat your-key.pem | awk '{printf "%s\\n", $0}' | sed 's/\\n$//'
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# Nom du repo runner sur l'org cursus-app
CURSUS_HARNESS_RUNNER_REPO="cursus-app/cursus-harness-runner"

# Secret HMAC pour valider les webhooks GH Actions → Cursus
# Générer: openssl rand -hex 32
GITHUB_APP_WEBHOOK_SECRET="changeme-hex-32"


# ---------------------------------------------------------------------
# 5. RESEND — Emails transactionnels
# ---------------------------------------------------------------------

# API Key (Dashboard Resend → API Keys → Create)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Adresse expéditrice (doit être sur un domaine vérifié)
RESEND_FROM_EMAIL="hello@cursus.app"

# Nom expéditeur affiché
RESEND_FROM_NAME="Cursus"

# Secret webhook pour valider les events Resend (delivery, bounce, etc.)
# À configurer côté Resend dans Settings → Webhooks
RESEND_WEBHOOK_SECRET="changeme-resend-webhook"


# ---------------------------------------------------------------------
# 6. SENTRY — Monitoring erreurs + traces
# ---------------------------------------------------------------------

# DSN (Sentry Dashboard → Settings → Client Keys (DSN)) — public, lu côté client
NUXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxx@oXXXXXXX.ingest.sentry.io/XXXXXXXXX"

# Auth token pour upload des source maps (Settings → Auth Tokens)
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxx"

# Slug de l'organisation Sentry
SENTRY_ORG="cursus"

# Slug du projet Sentry
SENTRY_PROJECT="cursus-app"

# Sample rate des traces en prod (0.0 à 1.0, recommandé 0.1-0.25)
SENTRY_TRACES_SAMPLE_RATE="0.25"


# ---------------------------------------------------------------------
# 7. POSTHOG — Web analytics RGPD-friendly (free tier 1M events/mois)
# ---------------------------------------------------------------------
# Choix : PostHog Cloud Free (1M events/mois gratuit, session replay,
# feature flags inclus) au lieu de Plausible (payant dès $9/mois).

# Public project API key (côté client OK)
NUXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxx"

# Host PostHog (EU pour conformité RGPD)
NUXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"


# ---------------------------------------------------------------------
# 8. INNGEST — Queue & jobs async
# ---------------------------------------------------------------------

# Event key (envoyer des events vers Inngest)
INNGEST_EVENT_KEY="evnt_xxxxxxxxxxxx"

# Signing key (valider les requêtes Inngest → app)
INNGEST_SIGNING_KEY="signkey-prod-xxxxxxxxxxxx"

# Optionnel : URL self-hosted Inngest (laisser vide pour cloud)
INNGEST_BASE_URL=""


# ---------------------------------------------------------------------
# 9. UPSTASH REDIS — Cache + Rate limiting
# ---------------------------------------------------------------------

# REST URL (Dashboard Upstash → Database → Details → REST API)
UPSTASH_REDIS_REST_URL="https://xxxxxxxxxxxx.upstash.io"

# Token associé
UPSTASH_REDIS_REST_TOKEN="AY...."


# ---------------------------------------------------------------------
# 10. CHROMATIC — Tests visuels Storybook
# ---------------------------------------------------------------------

# Project token (Chromatic dashboard → Manage → Project token)
CHROMATIC_PROJECT_TOKEN="chpt_xxxxxxxxxxxx"


# ---------------------------------------------------------------------
# 11. CERTIFICAT — Signature numérique
# ---------------------------------------------------------------------

# Clé privée Ed25519 pour signer les certificats PDF (PEM en base64 url-safe)
# Générer: openssl genpkey -algorithm ED25519 -out cert-private.pem
#          puis cat cert-private.pem | base64 -w 0
# Stocker la version base64 ici, JAMAIS la clé brute
CERTIFICATE_SIGNING_KEY="changeme-base64-ed25519-private"

# Clé publique correspondante (pour la vérification publique du certif)
# openssl pkey -in cert-private.pem -pubout -out cert-public.pem
CERTIFICATE_SIGNING_PUBLIC_KEY_B64="changeme-base64-ed25519-public"


# ---------------------------------------------------------------------
# 12. CAPTCHA — Protection brute force auth (Cloudflare Turnstile)
# ---------------------------------------------------------------------

# Site key (public, côté client) — Cloudflare Dashboard → Turnstile
NUXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA..."

# Secret key (privée, côté serveur)
TURNSTILE_SECRET_KEY="0x4AAAAAAA..."


# ---------------------------------------------------------------------
# 13. LLM (post-MVP — EP-21 AI Assist, v1.1)
# ---------------------------------------------------------------------

# À laisser vide au MVP, à remplir quand EP-21 démarre
# Anthropic API key (pour Claude Haiku — recommandé par ratio coût/qualité)
ANTHROPIC_API_KEY=""


# ---------------------------------------------------------------------
# 14. DIVERS & OBSERVABILITÉ
# ---------------------------------------------------------------------

# Logtail / BetterStack source token (ingestion logs Pino)
# Laisser vide au MVP, à brancher quand le volume justifie
LOGTAIL_SOURCE_TOKEN=""

# OAuth GitHub (pour la connexion stagiaire)
# Créer dans GitHub → Settings → Developer settings → OAuth Apps
GITHUB_OAUTH_CLIENT_ID="Iv1.xxxxxxxxxxxx"
GITHUB_OAUTH_CLIENT_SECRET="changeme-github-oauth-secret"


# =====================================================================
# Vérifications avant `pnpm dev`
# =====================================================================
# - [ ] DATABASE_URL et DIRECT_URL pointent vers le bon projet Supabase
# - [ ] SUPABASE_SERVICE_ROLE_KEY n'est PAS commitée
# - [ ] CURSUS_GITHUB_APP_PRIVATE_KEY est correctement formatée (\n littéraux)
# - [ ] CURSUS_HARNESS_WEBHOOK_SECRET généré aléatoirement (32+ bytes)
# - [ ] CERTIFICATE_SIGNING_*_KEY_B64 ne sont PAS partagés
# - [ ] NUXT_SESSION_SECRET généré aléatoirement
# - [ ] RESEND_FROM_EMAIL est sur un domaine DKIM-vérifié
# =====================================================================
