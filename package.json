{
  "name": "cursus",
  "version": "0.1.0",
  "private": true,
  "description": "Cursus — gestion de parcours de stages tech",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "nuxt build",
    "vercel-build": "prisma generate && prisma migrate deploy && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:rls": "vitest run tests/rls/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/seo": "^5.3.0",
    "@nuxtjs/supabase": "^2.0.9",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nuxt": "^10.59.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vee-validate/zod": "^4.15.1",
    "@vue-email/render": "^0.0.9",
    "@vueuse/motion": "^2.2.6",
    "@vueuse/nuxt": "^14.3.0",
    "dotenv": "^16.4.0",
    "inngest": "^4.7.0",
    "motion-v": "^2.3.0",
    "nuxt": "^4.4.8",
    "nuxt-security": "^2.6.0",
    "pg": "^8.13.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "resend": "^6.14.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.38",
    "vue-draggable-plus": "^0.6.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.0",
    "@storybook/vue3": "10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "chromatic": "^17.5.0",
    "eslint": "^10.0.0",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "//": "La config 'prisma' (seed, etc.) a été déplacée dans prisma.config.ts (requis depuis Prisma 7)."
}
