      "pluginVersion": "11.0.0",
      "title": "Utilisateurs actifs dans le temps (DAU / WAU)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', created_at) AS time,\n  COUNT(DISTINCT user_id) AS dau\nFROM user_activity_logs\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
