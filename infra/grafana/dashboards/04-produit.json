      "pluginVersion": "11.0.0",
      "title": "Soumissions par jour",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', submitted_at) AS time,\n  COUNT(*) FILTER (WHERE status = 'success') AS reussies,\n  COUNT(*) FILTER (WHERE status = 'failure') AS echecs,\n  COUNT(*) FILTER (WHERE status = 'pending') AS en_attente\nFROM submissions\nWHERE $__timeFilter(submitted_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    },
