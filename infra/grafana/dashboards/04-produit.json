      "pluginVersion": "11.0.0",
      "title": "Statut capstones",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE status\n    WHEN 'pending' THEN 'En attente'\n    WHEN 'in_progress' THEN 'En cours'\n    WHEN 'done' THEN 'Termine'\n    WHEN 'failed' THEN 'Echoue'\n    ELSE status\n  END AS status_label,\n  COUNT(*) AS count\nFROM capstones\nGROUP BY status\nORDER BY count DESC",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
