      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Suivi des tentatives d'authentification, lockouts, exports RGPD et suppressions de compte.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["cursus"],
      "targetBlank": false,
      "title": "Tous les dashboards Cursus",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "tentatives/min",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [
              { "id": "displayName", "value": "Connexions reussies" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [
              { "id": "displayName", "value": "Echecs login" },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.0.0",
      "title": "Tentatives de login (succes vs echecs)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', created_at) AS time,\n  COUNT(CASE WHEN success = true THEN 1 END) AS success,\n  COUNT(CASE WHEN success = false THEN 1 END) AS failure\nFROM auth_logs\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "title": "Lockouts actifs",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM auth_lockouts WHERE expires_at > NOW()",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "title": "Exports RGPD cette semaine",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM gdpr_export_requests WHERE requested_at > date_trunc('week', NOW())",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "suppressions/jour",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "11.0.0",
      "title": "Suppressions de compte (droit a l'oubli)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', deleted_at) AS time,\n  COUNT(*) AS suppressions\nFROM users\nWHERE $__timeFilter(deleted_at)\n  AND deleted_at IS NOT NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "locked_at" },
            "properties": [
              { "id": "displayName", "value": "Date lockout" },
              { "id": "unit", "value": "dateTimeAsLocal" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "expires_at" },
            "properties": [
              { "id": "displayName", "value": "Expire le" },
              { "id": "unit", "value": "dateTimeAsLocal" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failed_attempts" },
            "properties": [
              { "id": "displayName", "value": "Tentatives echouees" },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null },
                    { "color": "red", "value": 10 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Date lockout" }]
      },
      "pluginVersion": "11.0.0",
      "title": "Lockouts actifs — detail",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  al.ip_address,\n  al.failed_attempts,\n  al.locked_at,\n  al.expires_at,\n  al.reason\nFROM auth_lockouts al\nWHERE al.expires_at > NOW()\nORDER BY al.locked_at DESC\nLIMIT 50",
          "refId": "A",
          "sql": {}
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "demandes",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "exports" },
            "properties": [
              { "id": "displayName", "value": "Exports RGPD" },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "suppressions" },
            "properties": [
              { "id": "displayName", "value": "Suppressions (droit a l'oubli)" },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.0.0",
      "title": "Activite RGPD (exports + suppressions) dans le temps",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', requested_at) AS time,\n  COUNT(*) AS exports\nFROM gdpr_export_requests\nWHERE $__timeFilter(requested_at)\nGROUP BY 1\nUNION ALL\nSELECT\n  date_trunc('day', deleted_at) AS time,\n  COUNT(*) AS suppressions\nFROM users\nWHERE $__timeFilter(deleted_at)\n  AND deleted_at IS NOT NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["cursus", "auth", "rgpd"],
  "templating": {
    "list": [
      {
        "current": {},
