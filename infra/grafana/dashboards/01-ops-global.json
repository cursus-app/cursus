        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.0.0",
      "title": "Latence API (p50 / p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', created_at) AS time,\n  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY duration_ms) AS p50,\n  PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY duration_ms) AS p95\nFROM api_logs\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    },
