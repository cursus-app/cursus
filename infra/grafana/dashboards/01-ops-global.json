      "title": "Taux erreurs 4xx (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  100.0 * COUNT(CASE WHEN status >= 400 AND status < 500 THEN 1 END) / NULLIF(COUNT(*), 0) AS value\nFROM api_logs\nWHERE created_at > NOW() - INTERVAL '1 hour'",
          "refId": "A",
          "sql": {}
        }
      ]
