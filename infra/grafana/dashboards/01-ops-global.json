          },
          {
            "matcher": { "id": "byName", "options": "errors_4xx" },
            "properties": [
              { "id": "displayName", "value": "4xx" },
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [
              { "id": "displayName", "value": "2xx" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.0.0",
      "title": "Taux d'erreur HTTP par minute",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', created_at) AS time,\n  COUNT(CASE WHEN status < 400 THEN 1 END) AS success,\n  COUNT(CASE WHEN status >= 400 AND status < 500 THEN 1 END) AS errors_4xx,\n  COUNT(CASE WHEN status >= 500 THEN 1 END) AS errors_5xx\nFROM api_logs\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ]
    }
