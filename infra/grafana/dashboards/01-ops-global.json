          "datasource": { "type": "postgres", "uid": "${DS_CURSUS_POSTGRES}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 100.0 * COUNT(CASE WHEN status < 500 THEN 1 END) / NULLIF(COUNT(*), 0) AS value FROM api_logs WHERE created_at > NOW() - INTERVAL '24 hours'",
