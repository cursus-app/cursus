        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "cursus",
        "query": "SELECT title FROM cursus ORDER BY title",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Cursus"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
