    "refresh_intervals": ["30s", "1m", "5m", "15m"],
    "time_options": ["1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "Europe/Paris",
  "title": "Cursus — Harnais CI",
  "uid": "cursus-harnais",
  "version": 1,
  "weekStart": "monday"
}
